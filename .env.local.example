# Copy this file to ".env.local" for local testing, OR set these in Vercel.
# The first two are PUBLIC (safe in the browser). The third is SECRET (server only).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# SECRET — never share this, never commit it. Get it from Supabase:
# Settings > API Keys > Secret keys  (starts with sb_secret_)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
